{
  "name": "@x-oasis/async-call-rpc-electron",
  "version": "0.3.0",
  "description": "Electron transport adapters (ipcMain, ipcRenderer, MessagePortMain, UtilityProcess) for @x-oasis/async-call-rpc",
  "main": "src/index.ts",
  "typings": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./electron-browser": {
      "types": "./dist/src/electron-browser/index.d.ts",
      "import": "./src/electron-browser/index.ts",
      "require": "./src/electron-browser/index.ts"
    },
    "./electron-main": {
      "types": "./dist/src/electron-main/index.d.ts",
      "import": "./src/electron-main/index.ts",
      "require": "./src/electron-main/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdx build --tsconfig tsconfig.build.json",
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "tsdx": "^0.14.1",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@x-oasis/async-call-rpc": "workspace:*"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  }
}
