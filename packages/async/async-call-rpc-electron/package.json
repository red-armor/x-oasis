{
  "name": "@x-oasis/async-call-rpc-electron",
  "version": "0.13.0",
  "type": "module",
  "description": "Electron transport adapters (ipcMain, ipcRenderer, MessagePortMain, UtilityProcess) for @x-oasis/async-call-rpc",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "require": "./dist/browser/index.js"
    },
    "./browser/core": {
      "types": "./dist/browser/core.d.ts",
      "import": "./dist/browser/core.js",
      "require": "./dist/browser/core.js"
    },
    "./browser/orchestrator": {
      "types": "./dist/browser/orchestrator.d.ts",
      "import": "./dist/browser/orchestrator.js",
      "require": "./dist/browser/orchestrator.js"
    },
    "./electron-browser/core": {
      "types": "./dist/electron-browser/core.d.ts",
      "import": "./dist/electron-browser/core.js",
      "require": "./dist/electron-browser/core.js"
    },
    "./electron-browser/orchestrator": {
      "types": "./dist/electron-browser/orchestrator.d.ts",
      "import": "./dist/electron-browser/orchestrator.js",
      "require": "./dist/electron-browser/orchestrator.js"
    },
    "./electron-main/core": {
      "types": "./dist/electron-main/core.d.ts",
      "import": "./dist/electron-main/core.js",
      "require": "./dist/electron-main/core.js"
    },
    "./electron-main/orchestrator": {
      "types": "./dist/electron-main/orchestrator.d.ts",
      "import": "./dist/electron-main/orchestrator.js",
      "require": "./dist/electron-main/orchestrator.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run compile && rollup -c",
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.3",
    "tsdx": "^0.14.1",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@x-oasis/async-call-rpc": "workspace:*",
    "@x-oasis/async-call-rpc-web": "workspace:*"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  }
}
