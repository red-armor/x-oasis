{
  "name": "@x-oasis/async-call-rpc",
  "version": "0.17.0",
  "description": "async-call-rpc function",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "module": "dist/async-call-rpc.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/async-call-rpc.esm.js",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.esm.js",
      "require": "./dist/core.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator/index.d.ts",
      "import": "./dist/orchestrator.esm.js",
      "require": "./dist/orchestrator.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run compile && rollup -c",
    "clean": "rimraf ./dist",
    "test": "vitest",
    "compile": "tsc -p tsconfig.build.json --emitDeclarationOnly"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.3",
    "tsdx": "^0.14.1",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@x-oasis/deferred": "workspace:*",
    "@x-oasis/disposable": "workspace:*",
    "@x-oasis/emitter": "workspace:*",
    "@x-oasis/id": "workspace:*",
    "@x-oasis/is-ascii": "workspace:*",
    "@x-oasis/is-function": "workspace:*",
    "@x-oasis/is-object": "workspace:*",
    "@x-oasis/is-promise": "workspace:*"
  }
}
