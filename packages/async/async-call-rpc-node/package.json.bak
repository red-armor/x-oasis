{
  "name": "@x-oasis/async-call-rpc-node",
  "version": "0.3.0",
  "description": "Node.js transport adapters (child_process.fork) for @x-oasis/async-call-rpc",
  "main": "src/index.ts",
  "typings": "src/index.ts",
  "module": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdx build --tsconfig tsconfig.build.json",
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "tsdx": "^0.14.1",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@x-oasis/async-call-rpc": "workspace:*"
  }
}
