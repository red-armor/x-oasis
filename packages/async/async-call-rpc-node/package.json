{
  "name": "@x-oasis/async-call-rpc-node",
  "version": "0.10.0",
  "description": "Node.js transport adapters (child_process.fork) for @x-oasis/async-call-rpc",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "module": "dist/async-call-rpc-node.esm.js",
  "exports": {
    ".": {
      "import": "./dist/async-call-rpc-node.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdx build --tsconfig tsconfig.build.json",
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "tsdx": "^0.14.1",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@x-oasis/async-call-rpc": "workspace:*"
  }
}
